APP_NAME=AI Scrum Master Agent
APP_VERSION=0.1.0

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_REASONING_MODEL=qwen2.5:1.5b-instruct
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_TIMEOUT=60
OLLAMA_NUM_CTX=1024
OLLAMA_TEMPERATURE=0.1

CHROMA_PERSIST_DIR=./data/chromadb
CHROMA_COLLECTION=project_context
RAG_BACKEND=langchain
RAG_FALLBACK_TO_DIRECT_CHROMA=true
RAG_CHUNK_SIZE=1200
RAG_CHUNK_OVERLAP=200
RAG_HYBRID_SEARCH=true
RAG_VECTOR_FETCH_K=20
PLANNER_PROMPT_VERSION=current
PLANNER_MAX_REPAIR_ATTEMPTS=3
RETRIEVAL_CONTEXT_TOP_K=3
RETRIEVAL_MIN_SCORE=0.6

JIRA_BASE_URL=https://your-company.atlassian.net
JIRA_PROJECT_KEY=SCRUM
JIRA_EMAIL=pm@example.com
JIRA_API_TOKEN=replace-with-atlassian-api-token

SLACK_WEBHOOK_URL=https://hooks.slack.com/services/replace/with/your-webhook
